# ─────────────────────────────────────────────────────────────
# Knockout — environment variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# App URL — used for OAuth callbacks, QStash callbacks, email links.
# Local: http://localhost:3000   Prod: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client)
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gmail SMTP (App Password — needs 2FA enabled on the account)
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Upstash QStash (https://console.upstash.com/qstash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
